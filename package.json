{
  "name": "toolmetry",
  "version": "1.0.4",
  "description": "A comprehensive developer tools library — Base64, URL encoding, hashing, JWT, UUID, AES-256 encryption, random generation, color conversion, HTML entities, number base, text utilities, JSON, password generator, Morse code, Roman numerals, cron validator, diff checker, lorem ipsum and more. Built by ToolmetryAI.",
  "main": "./src/index.js",
  "module": "./src/index.mjs",
  "types": "./src/index.d.ts",
  "type": "commonjs",
  "exports": {
    ".": {
      "import": "./src/index.mjs",
      "require": "./src/index.js",
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "src/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --test test/index.test.js",
    "prepublishOnly": "node -e \"console.log('Publishing toolmetry v' + require('./package.json').version)\""
  },
  "keywords": [
    "toolmetry",
    "toolmetryai",
    "developer-tools",
    "base64",
    "encode",
    "decode",
    "hash",
    "sha256",
    "md5",
    "jwt",
    "uuid",
    "aes-256",
    "encrypt",
    "decrypt",
    "random",
    "color-converter",
    "html-entities",
    "url-encoder",
    "number-base",
    "text-tools",
    "json",
    "password-generator",
    "morse-code",
    "roman-numerals",
    "cron-validator",
    "diff-checker",
    "lorem-ipsum",
    "utility",
    "crypto",
    "aes-gcm",
    "hmac"
  ],
  "author": "ToolmetryAI <contact@toolmetry.pro>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toolmetryai/toolmetry-npm.git"
  },
  "homepage": "https://toolmetry.pro",
  "bugs": {
    "url": "https://github.com/toolmetryai/toolmetry-npm/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/toolmetryai"
  }
}
